{
  "name": "db-restore",
  "version": "1.0.3",
  "description": "Database backup & restore for local development",
  "license": "MIT",
  "author": {
    "name": "Martín M.",
    "url": "https://github.com/skydiver/"
  },
  "type": "module",
  "bin": {
    "db-restore": "./build/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf build",
    "dev": "tsx watch src/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "volta": {
    "node": "24.13.1",
    "pnpm": "10.28.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "mysql2": "^3.20.0",
    "ora": "^9.3.0",
    "pg": "^8.20.0"
  }
}
